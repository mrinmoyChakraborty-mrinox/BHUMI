# --- Firebase ---
# Path to your Firebase service account JSON (download from Firebase Console >
# Project Settings > Service Accounts > Generate new private key)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# --- ImageKit (for image uploads — replaces Firebase Storage) ---
# Get these from https://imagekit.io/dashboard/developer/api-keys
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/RemediRX/BHUMI

# --- Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Public base URL Twilio can call back into (ngrok URL during dev, real domain in prod)
PUBLIC_BASE_URL=https://your-deployed-backend.example.com

# --- Google Maps (for geocoding district → lat/lon) ---
GOOGLE_MAPS_API_KEY=

# --- Weather (OpenWeatherMap, free tier) ---
OPENWEATHER_API_KEY=

# --- Rate Limiting ---
RATE_LIMIT_DEFAULT=30/minute
RATE_LIMIT_ALERT_TRIGGER=5/minute
RATE_LIMIT_HEALTH_LOG=10/minute
RATE_LIMIT_PUBLIC_PORTAL=10/minute

# --- Idempotency ---
# Minutes to block duplicate alert triggers for the same plot+type
IDEMPOTENCY_WINDOW_MINUTES=30

# --- Postgres / Supabase (reference data source) ---
# Postgres connection string for district/LGD/SHC/crop-calendar reference data
DATABASE_URL=

# --- Upload Limits ---
MAX_IMAGE_SIZE_MB=8

# --- App ---
ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Set to true ONLY when deployed behind a trusted reverse proxy / load balancer
# (e.g. Cloud Run, nginx). Enables X-Forwarded-For / X-Real-IP for rate limiting.
TRUST_PROXY=false
# Comma-separated list of Firebase UIDs allowed to hit admin-only endpoints
# without a custom claim set yet (optional bootstrap convenience)
ADMIN_BOOTSTRAP_UIDS=
