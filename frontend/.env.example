# FastAPI backend URL — this is where the frontend API client sends all requests.
# In dev with Vite proxy, you can leave this empty (proxy handles it).
# In production, set this to the deployed FastAPI URL, e.g. https://api.bhumi.example.com
VITE_API_BASE_URL=

# Firebase configuration — create a web app in Firebase Console to get these.
# https://console.firebase.google.com/project/_/settings/general/
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: Firebase Auth emulator for local dev
# VITE_FIREBASE_EMULATOR_HOST=http://localhost:9099
